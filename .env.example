# ─────────────────────────────────────────────────────────────────────────────
# TripForge — Environment Variables
# Copy this file to .env and fill in real values before running the app.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Get from: Supabase → project → Settings → Database → Connection string → URI
# Supabase provides a pooled URL for the app and a direct URL for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public&pgbouncer=true"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# Development: http://localhost:3000 | Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Setup at: console.cloud.google.com → APIs & Services → Credentials
# Add redirect URI: http://localhost:3000/api/auth/callback/google (dev)
#                   https://your-domain.com/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── DeepSeek (itinerary parsing + address enrichment) ────────────────────────
# Get from: platform.deepseek.com → API Keys
DEEPSEEK_API_KEY="sk-..."

# ── Google AI (Gemini — trip companion chat) ─────────────────────────────────
# Get from: aistudio.google.com → Get API key (free tier available)
GOOGLE_AI_API_KEY="AIza..."
# Optional: override the default model. Use gemini-1.5-flash if 2.0 hits quota limits.
# GEMINI_MODEL="gemini-1.5-flash"

# ── Mapbox ───────────────────────────────────────────────────────────────────
# Get from: account.mapbox.com → Tokens
MAPBOX_ACCESS_TOKEN="pk.eyJ1..."
# Same token — NEXT_PUBLIC_ prefix exposes it to the browser for the interactive map.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="pk.eyJ1..."
